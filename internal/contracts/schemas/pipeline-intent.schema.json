{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline-intent.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "issue_id",
    "work_order_id",
    "issue_type",
    "pipeline_family",
    "pipeline_selection",
    "policy_profile",
    "delivery_name",
    "requested_outcome",
    "deploy_as_unit",
    "selected_components",
    "ordered_components",
    "documentation",
    "testing",
    "environments"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "autodev-pipeline-intent-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "issue_id": { "type": "string", "minLength": 1 },
    "work_order_id": { "type": "string", "minLength": 1 },
    "issue_type": { "type": "string", "minLength": 1 },
    "pipeline_template": { "type": "string" },
    "pipeline_family": { "type": "string", "minLength": 1 },
    "pipeline_selection": { "type": "string", "minLength": 1 },
    "accepted_issue_types": { "type": "array", "items": { "type": "string" } },
    "optimization_goals": { "type": "array", "items": { "type": "string" } },
    "policy_profile": { "type": "string", "minLength": 1 },
    "delivery_name": { "type": "string", "minLength": 1 },
    "requested_outcome": { "type": "string", "minLength": 1 },
    "deploy_as_unit": { "type": "boolean" },
    "selected_components": { "type": "array", "items": { "type": "string" } },
    "ordered_components": { "type": "array", "items": { "type": "string" } },
    "documentation": { "type": "object" },
    "testing": { "type": "object" },
    "environments": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
