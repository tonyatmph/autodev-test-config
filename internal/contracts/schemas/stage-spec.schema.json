{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage-spec.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "operation",
    "operation_config",
    "runtime",
    "version",
    "tooling_repo",
    "prompt_file",
    "container",
    "allowed_secrets",
    "gitlab_scopes",
    "input_schema",
    "output_schema",
    "artifact_policy",
    "timeout_seconds",
    "retry_policy",
    "max_parallelism",
    "dependencies",
    "approval_required",
    "entrypoint"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "const": "orchestrate" },
    "operation_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "cwd": { "type": "string", "minLength": 1 },
              "command": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "success_criteria", "signal", "stats", "queue_mode"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 },
        "queue_mode": { "type": "string", "enum": ["auto", "triggered"] },
        "success_criteria": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "result_status": { "type": "string", "minLength": 1 },
            "require_summary": { "type": "boolean" },
            "required_outputs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "required_report_metadata": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "report_stages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "transitions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "on_success": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "on_failure": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "checkpoint_status": {
          "type": "string",
          "enum": ["pending", "active", "awaiting_approval", "completed", "failed"]
        },
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stage": { "type": "string", "minLength": 1 },
            "policy": { "type": "string", "minLength": 1 }
          }
        },
        "signal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["failure_severity"],
          "properties": {
            "failure_severity": { "type": "string", "minLength": 1 }
          }
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "tool_calls", "tooling_usd", "expected_artifacts"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "tool_calls": { "type": "integer", "minimum": 1 },
            "tooling_usd": { "type": "number", "exclusiveMinimum": 0 },
            "expected_artifacts": { "type": "integer", "minimum": 1 }
          }
        },
        "output_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "source"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "source": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "version": { "type": "string", "minLength": 1 },
    "tooling_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "ref"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 }
      }
    },
    "prompt_file": { "type": "string", "minLength": 1 },
    "container": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_as", "write_as", "permissions"],
      "properties": {
        "run_as": { "type": "string", "enum": ["agent", "generator", "governed"] },
        "write_as": { "type": "string", "enum": ["agent", "generator", "governed"] },
        "materialize": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["writable", "repo_control", "network", "runtime_user"],
          "properties": {
            "writable": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "repo_control": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "network": { "type": "string", "minLength": 1 },
            "runtime_user": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "enforcement"],
              "properties": {
                "mode": { "type": "string", "enum": ["shared-process", "host-user", "container-user"] },
                "os_user": { "type": "string", "minLength": 1 },
                "container_user": { "type": "string", "minLength": 1 },
                "enforcement": { "type": "string", "enum": ["advisory", "required"] }
              }
            }
          }
        }
      }
    },
    "allowed_secrets": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "gitlab_scopes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "artifact_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "retention", "publish_to_gitlab", "signed_summaries", "attach_manifests"],
      "properties": {
        "required": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "retention": { "type": "string", "minLength": 1 },
        "publish_to_gitlab": { "type": "boolean" },
        "signed_summaries": { "type": "boolean" },
        "attach_manifests": { "type": "boolean" }
      }
    },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_attempts", "backoff_secs"],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "backoff_secs": { "type": "integer", "minimum": 0 }
      }
    },
    "max_parallelism": { "type": "integer", "minimum": 1 },
    "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "approval_required": { "type": "boolean" },
    "entrypoint": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
