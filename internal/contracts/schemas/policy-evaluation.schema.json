{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "policy-evaluation.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "issue_id",
    "work_order_id",
    "policy_profile",
    "outcome",
    "pipeline_scope",
    "hierarchy",
    "stage_scope",
    "stage_policies"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "autodev-policy-evaluation-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "issue_id": { "type": "string", "minLength": 1 },
    "work_order_id": { "type": "string", "minLength": 1 },
    "policy_profile": { "type": "string", "minLength": 1 },
    "outcome": { "type": "string", "minLength": 1 },
    "pipeline_scope": { "type": "array", "items": { "type": "object" } },
    "hierarchy": { "type": "array", "items": { "type": "object" } },
    "stage_scope": { "type": "object" },
    "stage_policies": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
