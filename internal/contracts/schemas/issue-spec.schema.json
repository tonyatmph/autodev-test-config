{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue-spec.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["approval", "work_order", "metadata"],
  "properties": {
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "approved": { "type": "boolean" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": ["string", "null"] }
      }
    },
    "work_order": { "$ref": "#/$defs/workOrder" },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "repoTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_path", "default_branch", "working_branch_prefix", "ref", "materialization_path"],
      "properties": {
        "project_path": { "type": "string", "minLength": 1 },
        "default_branch": { "type": "string", "minLength": 1 },
        "working_branch_prefix": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "materialization_path": { "type": "string", "minLength": 1 }
      }
    },
    "gitopsTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_path", "environment", "path", "promotion_branch", "cluster", "ref", "materialization_path"],
      "properties": {
        "project_path": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "promotion_branch": { "type": "string", "minLength": 1 },
        "cluster": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "materialization_path": { "type": "string", "minLength": 1 }
      }
    },
    "ownershipRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "mutable"],
      "properties": {
        "identity": { "type": "string", "enum": ["agent", "generator", "governed"] },
        "paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "mutable": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "releaseDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "application": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact_name", "image_repo"],
          "properties": {
            "artifact_name": { "type": "string", "minLength": 1 },
            "image_repo": { "type": "string", "minLength": 1 }
          }
        },
        "infrastructure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ref": { "type": "string", "minLength": 1 },
            "gitops_only": { "type": "boolean" },
            "terraform_root": { "type": "string", "minLength": 1 }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bundle_ref": { "type": "string", "minLength": 1 },
            "compatibility": { "type": "string", "minLength": 1 },
            "gitops_managed_job": { "type": "boolean" }
          }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "deployable", "repo"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "deployable": { "type": "boolean" },
        "depends_on": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "repo": { "$ref": "#/$defs/repoTarget" },
        "ownership": { "type": "array", "items": { "$ref": "#/$defs/ownershipRule" } },
        "release": { "$ref": "#/$defs/releaseDefinition" }
      }
    },
    "environmentTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "gitops_repo", "approval_required", "rollout_strategy"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "gitops_repo": { "$ref": "#/$defs/gitopsTarget" },
        "approval_required": { "type": "boolean" },
        "rollout_strategy": { "type": "string", "minLength": 1 },
        "runtime_secret_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "provider", "ref"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "provider": { "type": "string", "minLength": 1 },
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "documentationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "docs_component"],
      "properties": {
        "required": { "type": "boolean" },
        "docs_component": { "type": "string", "minLength": 1 },
        "required_kinds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "deliveryTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "primary_component", "selected_components", "deploy_as_unit", "documentation", "journal", "components", "environments", "release"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "primary_component": { "type": "string", "minLength": 1 },
        "selected_components": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "deploy_as_unit": { "type": "boolean" },
        "documentation": { "$ref": "#/$defs/documentationPolicy" },
        "journal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "repo", "strategy"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "repo": { "$ref": "#/$defs/repoTarget" },
            "path": { "type": "string", "minLength": 1 },
            "strategy": { "type": "string", "minLength": 1 },
            "description": { "type": "string" }
          }
        },
        "components": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/component" }
        },
        "environments": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "local": { "$ref": "#/$defs/environmentTarget" },
            "dev": { "$ref": "#/$defs/environmentTarget" },
            "prod": { "$ref": "#/$defs/environmentTarget" }
          }
        },
        "release": { "$ref": "#/$defs/releaseDefinition" }
      }
    },
    "translation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["translator", "version", "status", "warnings"],
      "properties": {
        "translator": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "issuerAuthority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["can_create_pipeline"],
      "properties": {
        "can_create_pipeline": { "type": "boolean" },
        "roles": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "inspectionPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "category", "immutable", "readable_by_agent", "executable_by_agent"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "immutable": { "type": "boolean" },
        "readable_by_agent": { "type": "boolean" },
        "executable_by_agent": { "type": "boolean" }
      }
    },
    "testingPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "immutable", "readable_by_agent", "executable_by_agent", "inspection_points"],
      "properties": {
        "strategy": { "type": "string", "minLength": 1 },
        "immutable": { "type": "boolean" },
        "readable_by_agent": { "type": "boolean" },
        "executable_by_agent": { "type": "boolean" },
        "inspection_points": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/inspectionPoint" }
        }
      }
    },
    "workOrder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "issue_type", "requested_outcome", "policy_profile", "pipeline_template", "issuer_authority", "testing", "translation", "delivery"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source_issue_id": { "type": "string", "minLength": 1 },
        "issue_type": { "type": "string", "minLength": 1 },
        "requested_outcome": { "type": "string", "minLength": 1 },
        "policy_profile": { "type": "string", "minLength": 1 },
        "pipeline_template": { "type": "string", "minLength": 1 },
        "issuer_authority": { "$ref": "#/$defs/issuerAuthority" },
        "testing": { "$ref": "#/$defs/testingPolicy" },
        "translation": { "$ref": "#/$defs/translation" },
        "delivery": { "$ref": "#/$defs/deliveryTarget" }
      }
    }
  }
}
