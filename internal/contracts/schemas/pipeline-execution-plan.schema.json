{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline-execution-plan.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "issue_id",
    "work_order_id",
    "issue_type",
    "pipeline_family",
    "pipeline_selection",
    "testing",
    "delivery_name",
    "stages"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "autodev-pipeline-execution-plan-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "issue_id": { "type": "string", "minLength": 1 },
    "work_order_id": { "type": "string", "minLength": 1 },
    "issue_type": { "type": "string", "minLength": 1 },
    "pipeline_family": { "type": "string", "minLength": 1 },
    "pipeline_selection": { "type": "string", "minLength": 1 },
    "optimization_goals": { "type": "array", "items": { "type": "string" } },
    "testing": { "type": "object" },
    "delivery_name": { "type": "string", "minLength": 1 },
    "checkpoint_status": { "type": "string" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "dependencies",
          "queue_mode",
          "transitions",
          "container",
          "success_criteria",
          "output_artifacts",
          "report_stages",
          "image_ref",
          "image_digest",
          "entrypoint"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "spec": { "type": "object" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "environment": { "type": "string" },
          "queue_mode": { "type": "string", "minLength": 1 },
          "transitions": { "type": "object" },
          "checkpoint_status": { "type": "string" },
          "run_as": { "type": "string" },
          "write_as": { "type": "string" },
          "container": { "type": "object" },
          "success_criteria": { "type": "object" },
          "output_artifacts": { "type": "array", "items": { "type": "object" } },
          "report_stages": { "type": "array", "items": { "type": "string" } },
          "image_ref": { "type": "string", "minLength": 1 },
          "image_digest": { "type": "string", "minLength": 1 },
          "entrypoint": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
