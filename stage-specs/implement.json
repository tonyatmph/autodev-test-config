{
  "name": "implement",
  "operation": "orchestrate",
  "operation_config": {
    "steps": [
      {
        "name": "implement",
        "command": [
          "/bin/true"
        ]
      }
    ]
  },
  "runtime": {
    "summary": "Prepared implementation bundles for the requested repository targets.",
    "success_criteria": {
      "require_summary": true,
      "required_outputs": [
        "implementation_bundle",
        "mr_proposal"
      ],
      "required_report_metadata": [
        "state_transitions",
        "step_log"
      ]
    },
    "transitions": {
      "on_success": [
        "generate",
        "security",
        "test",
        "review"
      ]
    },
    "signal": {
      "failure_severity": "medium"
    },
    "stats": {
      "model": "autodev-stage-v1",
      "tool_calls": 4,
      "tooling_usd": 0.0006,
      "expected_artifacts": 3
    },
    "queue_mode": "auto"
  },
  "version": "v1",
  "tooling_repo": {
    "url": "tooling/implement",
    "ref": "main"
  },
  "prompt_file": "prompts/implement.md",
  "container": {
    "run_as": "agent",
    "write_as": "agent",
    "materialize": [
      "components"
    ],
    "permissions": {
      "writable": [
        "components"
      ],
      "repo_control": [
        "components"
      ],
      "network": "restricted",
      "runtime_user": {
        "mode": "container-user",
        "container_user": "agent",
        "enforcement": "required"
      }
    }
  },
  "allowed_secrets": [
    "gitlab-write-token"
  ],
  "gitlab_scopes": [
    "api:comment_issue",
    "api:write_repository"
  ],
  "input_schema": {
    "type": "plan_bundle"
  },
  "output_schema": {
    "type": "stage_result"
  },
  "artifact_policy": {
    "required": [
      "result",
      "evidence"
    ],
    "retention": "30d",
    "publish_to_gitlab": true,
    "signed_summaries": true,
    "attach_manifests": true
  },
  "timeout_seconds": 900,
  "retry_policy": {
    "max_attempts": 2,
    "backoff_secs": 60
  },
  "max_parallelism": 2,
  "dependencies": [
    "plan"
  ],
  "approval_required": false,
  "entrypoint": [
    "autodev-stage-runtime"
  ]
}