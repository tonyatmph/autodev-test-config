{
  "name": "observe_local",
  "operation": "orchestrate",
  "operation_config": {
    "steps": [
      {
        "name": "observe_local",
        "command": [
          "/bin/true"
        ]
      }
    ]
  },
  "runtime": {
    "environment": "local",
    "summary": "Observed rollout health for local after GitOps reconciliation.",
    "success_criteria": {
      "require_summary": true,
      "required_outputs": [
        "rollout"
      ],
      "required_report_metadata": [
        "state_transitions",
        "step_log"
      ]
    },
    "transitions": {
      "on_success": [
        "promote_dev"
      ]
    },
    "signal": {
      "failure_severity": "medium"
    },
    "stats": {
      "model": "autodev-stage-v1",
      "tool_calls": 1,
      "tooling_usd": 0.0006,
      "expected_artifacts": 3
    },
    "queue_mode": "auto"
  },
  "version": "v1",
  "tooling_repo": {
    "url": "tooling/observe_local",
    "ref": "main"
  },
  "prompt_file": "prompts/observe_local.md",
  "container": {
    "run_as": "governed",
    "write_as": "governed",
    "permissions": {
      "writable": [],
      "repo_control": [],
      "network": "restricted",
      "runtime_user": {
        "mode": "container-user",
        "container_user": "governed",
        "enforcement": "required"
      }
    }
  },
  "allowed_secrets": [],
  "gitlab_scopes": [
    "api:comment_issue"
  ],
  "input_schema": {
    "type": "local_promotion_bundle"
  },
  "output_schema": {
    "type": "stage_result"
  },
  "artifact_policy": {
    "required": [
      "result",
      "evidence"
    ],
    "retention": "30d",
    "publish_to_gitlab": true,
    "signed_summaries": true,
    "attach_manifests": true
  },
  "timeout_seconds": 180,
  "retry_policy": {
    "max_attempts": 2,
    "backoff_secs": 20
  },
  "max_parallelism": 2,
  "dependencies": [
    "promote_local"
  ],
  "approval_required": false,
  "entrypoint": [
    "autodev-stage-runtime"
  ]
}