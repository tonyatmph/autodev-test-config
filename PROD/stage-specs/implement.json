{
  "operation": "orchestrate",
  "version": "1.0.0",
  "operation_config": {
    "steps": [
      {
        "command": [
          "/tooling/implement/run.sh"
        ]
      }
    ]
  },
  "runtime": {
    "summary": "Automated stage: implement",
    "queue_mode": "auto",
    "success_criteria": {
      "result_status": "success"
    },
    "signal": {
      "failure_severity": "high"
    },
    "stats": {
      "model": "gpt-4",
      "tool_calls": 1,
      "tooling_usd": 0.01,
      "expected_artifacts": 1
    }
  },
  "tooling_repo": {
    "url": "https://gitlab.com/mph.tech/tooling.git",
    "ref": "main"
  },
  "prompt_file": "prompts/implement.md",
  "container": {
    "run_as": "agent",
    "write_as": "agent",
    "permissions": {
      "writable": [
        "/workspace"
      ],
      "repo_control": [
        "none"
      ],
      "network": "restricted",
      "runtime_user": {
        "mode": "container-user",
        "enforcement": "required"
      }
    }
  },
  "allowed_secrets": [],
  "gitlab_scopes": [
    "api"
  ],
  "input_schema": {},
  "output_schema": {},
  "artifact_policy": {
    "required": [],
    "retention": "30d",
    "publish_to_gitlab": false,
    "signed_summaries": false,
    "attach_manifests": false
  },
  "timeout_seconds": 300,
  "retry_policy": {
    "max_attempts": 3,
    "backoff_secs": 10
  },
  "max_parallelism": 1,
  "approval_required": false,
  "name": "implement",
  "entrypoint": [
    "/tooling/implement/run.sh"
  ],
  "dependencies": []
}
