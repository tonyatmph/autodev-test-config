{
  "name": "generate",
  "operation": "orchestrate",
  "operation_config": {
    "steps": [
      {
        "name": "generate",
        "command": [
          "/bin/true"
        ]
      }
    ]
  },
  "runtime": {
    "summary": "Materialized generated outputs for the selected components.",
    "success_criteria": {
      "require_summary": true,
      "required_outputs": [
        "generated_components",
        "generation_report"
      ],
      "required_report_metadata": [
        "state_transitions",
        "step_log"
      ]
    },
    "signal": {
      "failure_severity": "medium"
    },
    "stats": {
      "model": "autodev-stage-v1",
      "tool_calls": 2,
      "tooling_usd": 0.0006,
      "expected_artifacts": 3
    },
    "queue_mode": "auto"
  },
  "version": "v1",
  "tooling_repo": {
    "url": "tooling/implement",
    "ref": "main"
  },
  "prompt_file": "prompts/implement.md",
  "container": {
    "run_as": "generator",
    "write_as": "generator",
    "materialize": [
      "components",
      "journal"
    ],
    "permissions": {
      "writable": [
        "components",
        "journal"
      ],
      "repo_control": [
        "components",
        "journal"
      ],
      "network": "restricted",
      "runtime_user": {
        "mode": "container-user",
        "container_user": "generator",
        "enforcement": "required"
      }
    }
  },
  "allowed_secrets": [],
  "gitlab_scopes": [
    "api:comment_issue"
  ],
  "input_schema": {
    "type": "implementation_bundle"
  },
  "output_schema": {
    "type": "stage_result"
  },
  "artifact_policy": {
    "required": [
      "result",
      "evidence"
    ],
    "retention": "30d",
    "publish_to_gitlab": true,
    "signed_summaries": true,
    "attach_manifests": false
  },
  "timeout_seconds": 300,
  "retry_policy": {
    "max_attempts": 2,
    "backoff_secs": 30
  },
  "max_parallelism": 2,
  "dependencies": [
    "implement"
  ],
  "approval_required": false,
  "entrypoint": [
    "autodev-stage-runtime"
  ]
}